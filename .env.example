# Copy to .env (repo root) and fill in your key.

OPENAI_API_KEY=your-key-here

# Optional Embeddings — local sentence-transformers by default (no network needed).
# EMBEDDING_PROVIDER=openai
# EMBEDDING_MODEL=all-MiniLM-L6-v2

#  OpenAI embeddings (official openai SDK):
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small
# EMBEDDING_API_KEY=your-openai-key   # optional — defaults to OPENAI_API_KEY above
# EMBEDDING_BASE_URL=https://...   # only to target an OpenAI-compatible endpoint

# Optional: override where the persistent store is read from / written to
# (default: <repo>/data). Shared by the ETL pipeline and the inference side.
# DATA_DIR=/absolute/path/to/agorag/data
